# Peoties Telegram wrapper config.
# Copy to .env and fill in. Never commit the real .env.

# Telegram bot token from @BotFather. REQUIRED.
PEOTIES_BOT_TOKEN=

# Hermes API key. REQUIRED — must match the `API_SERVER_KEY` set in
# hermes-gateway's .env. Hermes refuses X-Hermes-Session-Id (i.e. per-user
# session continuity) without one, so wrapper auth and hermes config are
# coupled. Generate with: openssl rand -hex 32
HERMES_API_KEY=

# Hermes backend HTTP endpoint. Default assumes hermes-gateway runs on the
# same host with API_SERVER_ENABLED=true.
HERMES_API_URL=http://127.0.0.1:8642/v1/chat/completions

# Model name advertised by hermes api_server (matches /v1/models response).
HERMES_MODEL=hermes-agent

# Per-request timeout for the hermes call. Increase if intake conversations
# include heavy tool calls (e.g. multi-file KB search).
HERMES_TIMEOUT_SECONDS=180

# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
